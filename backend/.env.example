# Copy to backend/.env and fill in. backend/.env is git-ignored.
#
# NOTE: when running via `docker compose up`, the Supermemory URL and API key
# are handled automatically (the key is auto-discovered from the server's data
# volume) — you only need the EXTRACTOR_* / provider key lines below.
# The two SUPERMEMORY_* lines only matter when running the backend on the host.
SUPERMEMORY_API_URL=http://localhost:6767
# Printed by the container on first boot: docker logs supermemory-instance | grep sm_
SUPERMEMORY_API_KEY=sm_...

# LLM for extraction + judging. Any LiteLLM model string.
# Recommended: Groq free tier (fast 70B, free key from https://console.groq.com):
EXTRACTOR_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=

# Other options:
#   OpenAI (needs credit):   EXTRACTOR_MODEL=openai/gpt-4o        + OPENAI_API_KEY=
#   Anthropic:               EXTRACTOR_MODEL=anthropic/claude-... + ANTHROPIC_API_KEY=
#   Local Ollama (no key; 4B is unreliable on real prose):
#     EXTRACTOR_MODEL=ollama/gemma3:4b
#     # In Docker use host.docker.internal; on the host use localhost:
#     EXTRACTOR_API_BASE=http://host.docker.internal:11434

# Copy this file to `supermemory.env` (already git-ignored) and fill in ONE
# of the keys below. supermemory-server needs at least one LLM provider key
# for embeddings/summaries — pick whichever provider you have a key for.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=...

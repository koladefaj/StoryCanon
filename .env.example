# Root .env — read by docker-compose for the SUPERMEMORY container's own LLM.
# Copy to `.env` (git-ignored) and fill in. This key powers Supermemory's
# built-in extraction of memories from raw prose (the "Derived" view).
#
# Separate from backend/.env, which configures OUR extraction + judging pipeline.
# The two can share one OpenAI key or use different providers.

# Any OpenAI-compatible provider. gpt-4o-mini is plenty for prose extraction.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Local, no cloud key (alternative) ------------------------------------
# Point Supermemory at Ollama on the host instead of OpenAI:
#   OPENAI_API_KEY=ollama
#   OPENAI_BASE_URL=http://host.docker.internal:11434/v1
#   OPENAI_MODEL=gemma3:4b
